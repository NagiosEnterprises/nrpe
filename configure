	launchd) :
    inetddir=${inetddir="/Library/LaunchDaemons"}
		inetdname=${inetdname="org.nagios.$INIT_PROG.plist"} ;; #(
  *) :
    inetddir=${inetddir="unknown"}
		inetdname=${inetdname="unknown"} ;; #(
  *) :
     ;;
esac

{ printf "%s\n" "$as_me:${as_lineno-$LINENO}: result: $install_method" >&5
