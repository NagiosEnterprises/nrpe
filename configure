  darwin*) :
    opsys="osx" ;; #(
  *bsd*) :
    opsys="bsd" ;; #(
  dragonfly) :
    opsys="bsd" ;; #(
  sunos) :
    opsys="solaris" ;; #(
  gnu/hurd) :
    opsys="linux" ;; #(
  irix*) :
    opsys="irix" ;; #(
  cygwin*) :
    opsys="cygwin" ;; #(
  mingw*) :
    opsys="mingw" ;; #(
  msys*) :
    opsys="msys" ;; #(
  *) :
     ;;
esac
